# Gemini API key for content generation
GEMINI_API_KEY=your-gemini-api-key-here

# Gmail credentials (App Password — NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here

# Email recipient for draft posts
DRAFT_RECIPIENT=your-email@gmail.com

# Instagram Graph API (Phase 2)
# INSTAGRAM_ACCESS_TOKEN=your-token-here
# INSTAGRAM_BUSINESS_ACCOUNT_ID=your-account-id-here
